---
import type { Race } from '../utils/calendar';
import { getMonthGrid, getRacesInMonth, getRaceOnDay, getMonthName, getCalendarMonths, isPast, isToday } from '../utils/calendar';
import RaceWeekend from './RaceWeekend.astro';

interface Props {
  races: Race[];
  color: string;
}

const { races, color } = Astro.props;
const months = getCalendarMonths(races);
const weekDays = ['Lun', 'Mar', 'Mer', 'Gio', 'Ven', 'Sab', 'Dom'];

const today = new Date().toISOString().split('T')[0];
const [todayY, todayM] = today.split('-').map(Number);
// Find the default month: current month if it has races, otherwise first month with future races
const defaultMonth = months.find(m => m.year === todayY && m.month === todayM - 1)
  ?? months.find(m => {
    const monthEnd = new Date(m.year, m.month + 1, 0).toISOString().split('T')[0];
    return monthEnd >= today;
  })
  ?? months[0];
const defaultId = defaultMonth ? `${defaultMonth.year}-${defaultMonth.month}` : '';
---

<section class="max-w-5xl mx-auto px-4 py-6">
  <h2 class="text-lg font-bold text-white mb-4">Calendario completo</h2>

  <nav class="flex gap-2 overflow-x-auto pb-3 mb-6 scrollbar-hide" id="month-nav">
    {months.map(({ year, month }) => {
      const id = `${year}-${month}`;
      return (
        <button
          class:list={[
            'month-chip px-3 py-1.5 rounded-full text-sm font-medium whitespace-nowrap transition-colors flex-shrink-0',
            id === defaultId ? 'text-white' : 'bg-slate-800 text-slate-400 hover:text-white'
          ]}
          style={id === defaultId ? `background: ${color}` : undefined}
          data-month={id}
        >
          {getMonthName(month).slice(0, 3).charAt(0).toUpperCase() + getMonthName(month).slice(1, 3)} {year}
        </button>
      );
    })}
  </nav>

  <div id="months-container">
    {months.map(({ year, month }) => {
      const grid = getMonthGrid(year, month);
      const monthRaces = getRacesInMonth(races, year, month);
      const id = `${year}-${month}`;

      return (
        <div id={`month-${id}`} data-month={id} class:list={['month-section', id !== defaultId && 'hidden']}>
          <h3 class="text-base font-semibold text-slate-300 mb-3 capitalize">
            {getMonthName(month)} {year}
          </h3>

          <div class="grid grid-cols-7 gap-px bg-slate-800 rounded-lg overflow-hidden mb-4 text-center">
            {weekDays.map(d => (
              <div class="bg-slate-900 py-2 text-xs font-medium text-slate-500">{d}</div>
            ))}
            {grid.flat().map(day => {
              if (day === null) return <div class="bg-slate-900/50 py-2" />;
              const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
              const race = getRaceOnDay(races, year, month, day);
              const past = isPast(dateStr);
              const today = isToday(dateStr);

              return (
                <div class:list={[
                  'py-2 text-sm relative',
                  today ? 'bg-slate-700 font-bold text-white' : past ? 'bg-slate-900/50 text-slate-600' : 'bg-slate-900/50 text-slate-300',
                ]}>
                  {day}
                  {race && (
                    <span
                      class="absolute bottom-0.5 left-1/2 -translate-x-1/2 w-1.5 h-1.5 rounded-full"
                      style={`background: ${past ? '#475569' : color}`}
                    />
                  )}
                </div>
              );
            })}
          </div>

          {monthRaces.length > 0 && (
            <div class="space-y-3">
              {monthRaces.map(race => (
                <RaceWeekend race={race} color={color} />
              ))}
            </div>
          )}
        </div>
      );
    })}
  </div>
</section>

<script define:vars={{ color }}>
  document.querySelectorAll('.month-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const target = chip.dataset.month;
      document.querySelectorAll('.month-section').forEach(s => s.classList.add('hidden'));
      document.getElementById('month-' + target)?.classList.remove('hidden');
      document.querySelectorAll('.month-chip').forEach(c => {
        c.style.background = '';
        c.classList.remove('text-white');
        c.classList.add('bg-slate-800', 'text-slate-400');
      });
      chip.classList.remove('bg-slate-800', 'text-slate-400');
      chip.classList.add('text-white');
      chip.style.background = color;
    });
  });

  const today = new Date().toISOString().split('T')[0];
  const [todayY, todayM] = [today.slice(0, 4), today.slice(5, 7)];
  const todayMonthId = `${todayY}-${parseInt(todayM) - 1}`;
  
  const defaultChip = document.querySelector('.month-chip[data-month="' + todayMonthId + '"]');
  if (defaultChip) {
    document.querySelectorAll('.month-chip').forEach(c => {
      c.style.background = '';
      c.classList.remove('text-white');
      c.classList.add('bg-slate-800', 'text-slate-400');
    });
    defaultChip.classList.remove('bg-slate-800', 'text-slate-400');
    defaultChip.classList.add('text-white');
    defaultChip.style.background = color;
    
    document.querySelectorAll('.month-section').forEach(s => s.classList.add('hidden'));
    document.getElementById('month-' + todayMonthId)?.classList.remove('hidden');
  }

  document.querySelectorAll('.month-section').forEach(section => {
    const monthId = section.dataset.month;
    const [year, month] = monthId.split('-').map(Number);
    const monthEnd = new Date(year, month + 1, 0).toISOString().split('T')[0];
    const monthStart = new Date(year, month, 1).toISOString().split('T')[0];
    const isFuture = monthStart > today;
    const isPastMonth = monthEnd < today;
    
    section.querySelectorAll('.grid > div').forEach(cell => {
      const dayText = cell.textContent?.trim();
      if (!dayText || isNaN(parseInt(dayText))) return;
      
      const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${dayText.padStart(2, '0')}`;
      const isTodayDate = dateStr === today;
      const isPastDate = dateStr < today;
      
      cell.classList.remove('bg-slate-700', 'font-bold', 'text-white', 'bg-slate-900/50', 'text-slate-600', 'text-slate-300');
      
      if (isTodayDate) {
        cell.classList.add('bg-slate-700', 'font-bold', 'text-white');
      } else if (isPastDate) {
        cell.classList.add('bg-slate-900/50', 'text-slate-600');
      } else {
        cell.classList.add('bg-slate-900/50', 'text-slate-300');
      }
      
      const dot = cell.querySelector('span');
      if (dot) {
        dot.style.background = isPastDate ? '#475569' : color;
      }
    });
  });
</script>
