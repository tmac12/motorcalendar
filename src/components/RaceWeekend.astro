---
import type { Race } from '../utils/calendar';
import { getDayName, groupSessionsByDay, isToday, isRacePast, countryCodeToFlag } from '../utils/calendar';

interface Props {
  race: Race;
  color: string;
}

const { race, color } = Astro.props;
const past = isRacePast(race);
const sessionsByDay = groupSessionsByDay(race.sessions);
const days = Object.keys(sessionsByDay).sort();
const flag = countryCodeToFlag(race.countryCode);
---

<details class:list={[
  'race-weekend rounded-xl border overflow-hidden transition-colors',
  past ? 'border-slate-800 bg-slate-900/30' : 'border-slate-700/50 bg-slate-800/30'
]}>
  <summary class="px-4 py-3 flex items-center justify-between gap-3 cursor-pointer">
    <div class="flex items-center gap-3 min-w-0">
      <span class="text-lg flex-shrink-0" aria-label={race.country}>{flag}</span>
      <div class="min-w-0">
        <h3 class:list={[
          'font-semibold text-sm truncate',
          past ? 'text-slate-500' : 'text-white'
        ]}>
          {race.name}
        </h3>
        <p class:list={['text-xs', past ? 'text-slate-600' : 'text-slate-400']}>
          {race.circuit}
        </p>
      </div>
    </div>
    <div class="flex items-center gap-2 flex-shrink-0">
      <span class:list={['text-xs font-mono race-dates', past ? 'text-slate-600' : 'text-slate-400']}>
        {new Date(race.startDate + 'T00:00:00').getDate()}-{new Date(race.endDate + 'T00:00:00').getDate()}/{new Date(race.startDate + 'T00:00:00').getMonth() + 1}
      </span>
      <svg class="w-4 h-4 text-slate-500 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </summary>
  <div class="px-4 pb-4 border-t border-slate-700/30">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 pt-3">
      {days.map(day => {
        const dayIsToday = isToday(day);
        return (
          <div>
            <h4 class:list={[
              'text-xs font-bold uppercase tracking-wider mb-2 day-header',
              dayIsToday ? 'text-white' : 'text-slate-500'
            ]}>
              {getDayName(day)} {new Date(day + 'T00:00:00').getDate()}
              {dayIsToday && (
                <span class="ml-1.5 text-[10px] px-1.5 py-0.5 rounded-full text-white" style={`background: ${color}`}>
                  OGGI
                </span>
              )}
            </h4>
            <ul class="space-y-1.5">
              {sessionsByDay[day].map(session => {
                const isRace = session.shortName.startsWith('GARA');
                return (
                  <li>
                    <div class="flex items-center justify-between">
                      <span class:list={[
                        'text-xs',
                        isRace ? 'font-bold text-white' : 'text-slate-300'
                      ]}>
                        {session.name}
                      </span>
                      <time class:list={[
                        'text-xs font-mono tabular-nums',
                        isRace ? 'font-bold text-white' : 'text-slate-400'
                      ]}>
                        {session.time}
                      </time>
                    </div>
                    {session.tv && (
                      <div class="flex items-center justify-end gap-1 mt-0.5">
                        <svg class="w-2.5 h-2.5 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                        <span class="text-[10px] text-teal-400">{session.tv} ore {session.tvTime}</span>
                      </div>
                    )}
                  </li>
                );
              })}
            </ul>
          </div>
        );
      })}
    </div>
  </div>
</details>

<script define:vars={{ color }}>
  const today = new Date().toISOString().split('T')[0];
  const details = document.currentScript?.closest('.race-weekend');
  if (!details) return;
  
  const raceStart = details.querySelector('.race-dates')?.textContent?.match(/(\d+)-(\d+)\/(\d+)/);
  if (!raceStart) return;
  
  const startDay = parseInt(raceStart[1]);
  const endDay = parseInt(raceStart[2]);
  const month = parseInt(raceStart[3]);
  const year = details.closest('[data-month]')?.dataset.month?.split('-')[0] || new Date().getFullYear();
  
  const currentYear = new Date().getFullYear();
  const currentMonth = new Date().getMonth() + 1;
  
  let raceEndDate = today;
  if (year > currentYear || (year === currentYear && month > currentMonth) || (year === currentYear && month === currentYear)) {
    raceEndDate = `${year}-${String(month).padStart(2, '0')}-${String(endDay).padStart(2, '0')}`;
  } else {
    raceEndDate = `${currentYear}-${String(currentMonth).padStart(2, '0')}-${String(new Date().getDate()).padStart(2, '0')}`;
  }
  
  const isPastRace = raceEndDate < today;
  const summary = details.querySelector('summary');
  
  if (isPastRace) {
    details.classList.remove('border-slate-700/50', 'bg-slate-800/30');
    details.classList.add('border-slate-800', 'bg-slate-900/30');
    summary?.querySelectorAll('h3, p, span').forEach(el => {
      el.classList.remove('text-white', 'text-slate-400');
      el.classList.add('text-slate-500', 'text-slate-600');
    });
  }
  
  details.querySelectorAll('.day-header').forEach(header => {
    const dayText = header.textContent?.match(/\d+$/)?.[0];
    if (!dayText) return;
    const dayDate = `${year}-${String(month).padStart(2, '0')}-${dayText.padStart(2, '0')}`;
    const isTodayDate = dayDate === today;
    const isPastDate = dayDate < today;
    
    header.classList.remove('text-white', 'text-slate-500');
    header.classList.add(isTodayDate ? 'text-white' : isPastDate ? 'text-slate-500' : 'text-slate-500');
    
    const oggiBadge = header.querySelector('.oggi-badge');
    if (oggiBadge) {
      if (!isTodayDate) {
        oggiBadge.remove();
      }
    } else if (isTodayDate) {
      const span = document.createElement('span');
      span.className = 'oggi-badge ml-1.5 text-[10px] px-1.5 py-0.5 rounded-full text-white';
      span.style.background = color;
      span.textContent = 'OGGI';
      header.appendChild(span);
    }
  });
</script>
